# 应用配置
APP_NAME=在线试卷系统
APP_VERSION=1.0.0
DEBUG=False

# 服务器配置
HOST=0.0.0.0
PORT=8000
RELOAD=True

# 安全配置
SECRET_KEY=your-secret-key-change-in-production-please-use-a-random-string
TOKEN_EXPIRE_DAYS=7
PASSWORD_MIN_LENGTH=6

# CORS 配置（生产环境请修改为实际域名）
CORS_ORIGINS=["*"]

# 日志配置
# 日志级别：DEBUG < INFO < WARNING < ERROR < CRITICAL
# DEBUG: 显示所有日志（开发环境）
# INFO: 显示一般信息及以上（默认）
# WARNING: 只显示警告和错误（生产环境推荐）
# ERROR: 只显示错误
LOG_LEVEL=INFO

# 日志文件路径（可选，不设置则只输出到控制台）
# LOG_FILE=logs/app.log

# 环境（development 或 production）
ENV=development
